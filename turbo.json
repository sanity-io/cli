{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**", ".sanity/**", "lib/**"]
    },
    "lint": {},
    "dev": {
      "cache": false,
      "persistent": true
    },
    "check:types": {},
    "watch": {},
    "test": {},
    "test:coverage": {},
    "test:watch": {}
  }
}
