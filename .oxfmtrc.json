{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "bracketSpacing": false,
  "printWidth": 100,
  "semi": false,
  "singleQuote": true,
  "sortPackageJson": {},
  "ignorePatterns": [
    ".vscode",
    ".turbo",
    "/packages/*/lib",
    "/packages/*/.turbo",
    "/packages/@sanity/*/lib",
    "/packages/@sanity/*/.turbo",
    "pnpm-lock.yaml",
    "CHANGELOG.md",
    ".release-please-manifest.json",
    "**/tsconfig.json",
    "**/__snapshots__/**",
    ".claude",
    ".changeset",
    "**/dist/**",
    "**/lib/**"
  ]
}
