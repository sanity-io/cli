{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "changelog-sections": [
    {
      "section": "Features",
      "type": "feat"
    },
    {
      "section": "Bug Fixes",
      "type": "fix"
    },
    {
      "section": "Performance Improvements",
      "type": "perf"
    },
    {
      "section": "Reverts",
      "type": "revert"
    },
    {
      "section": "Documentation",
      "type": "docs"
    },
    {
      "hidden": true,
      "section": "Styles",
      "type": "style"
    },
    {
      "hidden": true,
      "section": "Miscellaneous Chores",
      "type": "chore"
    },
    {
      "hidden": true,
      "section": "Code Refactoring",
      "type": "refactor"
    },
    {
      "hidden": true,
      "section": "Tests",
      "type": "test"
    },
    {
      "hidden": true,
      "section": "Build System",
      "type": "build"
    },
    {
      "hidden": true,
      "section": "Continuous Integration",
      "type": "ci"
    }
  ],
  "packages": {
    "packages/@sanity/cli-core": {
      "component": "cli-core",
      "release-type": "node"
    },
    "packages/@sanity/cli-test": {
      "component": "cli-test",
      "release-type": "node"
    },
    "packages/@sanity/cli": {
      "component": "cli",
      "release-type": "node"
    },
    "packages/@sanity/eslint-config-cli": {
      "component": "eslint-config-cli",
      "release-type": "node"
    }
  },
  "plugins": [
    {
      "type": "node-workspace",
      "updateAllPackages": false
    }
  ],
  "release-type": "node"
}
