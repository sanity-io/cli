{
  "name": "@sanity/cli-monorepo",
  "version": "0.0.1",
  "private": true,
  "description": "Command line tool monorepo for Sanity",
  "keywords": [
    "sanity",
    "cli"
  ],
  "homepage": "https://github.com/sanity-io/cli#readme",
  "bugs": {
    "url": "https://github.com/sanity-io/cli/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/sanity-io/cli.git"
  },
  "license": "MIT",
  "author": "Sanity.io <hello@sanity.io>",
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "build:cli": "turbo run build --filter=@sanity/cli && pnpm run build:types",
    "build:types": "turbo run build:types --filter=@sanity/cli --filter=@sanity/cli-core",
    "check": "npm run check:lint && npm run check:types",
    "check:lint": "turbo run lint -- --fix",
    "check:types": "turbo run check:types --filter=@sanity/cli --filter=@sanity/cli-core",
    "clean": "rimraf packages/@sanity/*/lib packages/*/lib packages/@sanity/*/dist packages/*/dist",
    "clean:deps": "rimraf packages/*/node_modules examples/*/node_modules node_modules",
    "depcheck": "knip",
    "dev": "turbo run dev",
    "extract-commands": "turbo run extract-commands",
    "format": "prettier --write .",
    "prepare": "husky",
    "pretest": "pnpm run build:cli",
    "test": "vitest run",
    "pretest:watch": "pnpm run build:cli",
    "test:watch": "vitest",
    "watch:cli": "turbo run watch --filter=@sanity/cli --filter=@sanity/cli-core"
  },
  "resolutions": {
    "@sanity/client": "^7.0.0"
  },
  "dependencies": {
    "@sanity/pkg-utils": "^7.11.9",
    "@types/node": "^20.19.25",
    "prettier": "^3.5.3",
    "prettier-plugin-packagejson": "^2.5.19"
  },
  "devDependencies": {
    "@eslint/compat": "catalog:",
    "@repo/eslint-config": "workspace:*",
    "@vitest/coverage-istanbul": "^3.2.4",
    "eslint": "catalog:",
    "husky": "^9.1.7",
    "knip": "^5.66.4",
    "lint-staged": "^16.2.6",
    "minimatch": "^10.1.1",
    "rimraf": "^5.0.10",
    "turbo": "^2.6.1",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@10.21.0",
  "engines": {
    "node": ">=20.19.1 <22 || >=22.12"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@swc/core",
      "esbuild"
    ],
    "overrides": {
      "@sanity/cli": "workspace:*"
    },
    "patchedDependencies": {
      "sanity": "patches/sanity.patch"
    }
  }
}
