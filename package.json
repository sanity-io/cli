{
  "name": "@sanity/cli-monorepo",
  "version": "0.0.1",
  "private": true,
  "description": "Command line tool monorepo for Sanity",
  "keywords": [
    "sanity",
    "cli"
  ],
  "homepage": "https://github.com/sanity-io/cli#readme",
  "bugs": {
    "url": "https://github.com/sanity-io/cli/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/sanity-io/cli.git"
  },
  "license": "MIT",
  "author": "Sanity.io <hello@sanity.io>",
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "build:cli": "turbo run build --filter=@sanity/cli",
    "check": "npm run check:lint && npm run check:types",
    "check:lint": "turbo run lint -- --fix",
    "check:types": "tsc --noEmit",
    "clean": "rimraf packages/@sanity/*/lib packages/*/lib packages/@sanity/*/dist packages/*/dist",
    "clean:deps": "rimraf packages/*/node_modules examples/*/node_modules node_modules",
    "dev": "turbo run dev",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "resolutions": {
    "@sanity/client": "^7.0.0"
  },
  "dependencies": {
    "@sanity/pkg-utils": "^7.2.1",
    "@types/node": "^20.17.23",
    "prettier": "^3.5.3",
    "prettier-plugin-packagejson": "^2.5.10",
    "tsx": "^4.19.3"
  },
  "devDependencies": {
    "@eslint/compat": "^1.2.9",
    "@repo/eslint-config": "workspace:*",
    "@vitest/coverage-v8": "^3.1.2",
    "eslint": "^9.26.0",
    "eslint-config-prettier": "^10.1.5",
    "rimraf": "^5.0.10",
    "turbo": "^2.4.4",
    "typescript": "^5.8.2",
    "vitest": "^3.1.2"
  },
  "packageManager": "pnpm@10.11.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@swc/core",
      "esbuild"
    ],
    "overrides": {
      "@sanity/cli": "workspace:*"
    },
    "patchedDependencies": {
      "sanity": "patches/sanity.patch"
    }
  }
}
