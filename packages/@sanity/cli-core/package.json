{
  "name": "@sanity/cli-core",
  "version": "0.1.0-alpha.4",
  "description": "Sanity CLI core package",
  "keywords": [
    "sanity",
    "cms",
    "headless",
    "realtime",
    "content",
    "cli",
    "tool"
  ],
  "homepage": "https://github.com/sanity-io/cli",
  "bugs": "https://github.com/sanity-io/cli/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sanity-io/cli.git",
    "directory": "packages/@sanity/cli-core"
  },
  "license": "MIT",
  "author": "Sanity.io <hello@sanity.io>",
  "type": "module",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.js"
    },
    "./tree": {
      "source": "./src/_exports/tree.ts",
      "require": "./dist/_exports/tree.js",
      "import": "./dist/_exports/tree.js"
    },
    "./ux": {
      "source": "./src/_exports/ux.ts",
      "require": "./dist/_exports/ux.js",
      "import": "./dist/_exports/ux.js"
    },
    "./package.json": "./package.json"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "./dist"
  ],
  "scripts": {
    "build": "swc --delete-dir-on-start --strip-leading-paths --out-dir dist/ src",
    "build:types": "tsc --project tsconfig.lib.json",
    "check:types": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "posttest": "pnpm run lint",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "watch": "swc --delete-dir-on-start --strip-leading-paths --out-dir dist/ --watch src"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.1.0",
    "@oclif/core": "catalog:",
    "@sanity/client": "catalog:",
    "@sanity/types": "^4.21.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "chalk": "^5.6.2",
    "configstore": "^7.0.0",
    "debug": "catalog:",
    "get-tsconfig": "catalog:",
    "import-meta-resolve": "^4.1.0",
    "jsdom": "catalog:",
    "json-lexer": "^1.2.0",
    "log-symbols": "^7.0.1",
    "ora": "^9.0.0",
    "tsx": "catalog:",
    "vite": "catalog:",
    "vite-node": "^3.0.8",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@eslint/compat": "catalog:",
    "@repo/tsconfig": "workspace:*",
    "@sanity/eslint-config-cli": "workspace:*",
    "@swc/cli": "catalog:",
    "@swc/core": "catalog:",
    "@types/debug": "catalog:",
    "@types/jsdom": "catalog:",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=20.19.1 <22 || >=22.12"
  },
  "publishConfig": {
    "access": "public"
  }
}
