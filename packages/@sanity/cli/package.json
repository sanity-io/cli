{
  "name": "@sanity/cli",
  "version": "6.0.0-alpha.17",
  "description": "Sanity CLI tool for managing Sanity projects and organizations",
  "keywords": [
    "sanity",
    "cms",
    "headless",
    "realtime",
    "content",
    "cli",
    "tool"
  ],
  "homepage": "https://github.com/sanity-io/cli",
  "bugs": "https://github.com/sanity-io/cli/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sanity-io/cli.git",
    "directory": "packages/@sanity/cli"
  },
  "license": "MIT",
  "author": "Sanity.io <hello@sanity.io>",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "source": "./src/exports/index.ts",
      "default": "./dist/exports/index.js"
    },
    "./_internal": {
      "source": "./src/exports/_internal.ts",
      "default": "./dist/exports/_internal.js"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/exports/index.js",
  "types": "./dist/exports/index.d.ts",
  "bin": {
    "sanity": "./bin/run.js"
  },
  "files": [
    "./bin",
    "./codemods",
    "./dist",
    "./oclif.config.js",
    "./oclif.manifest.json",
    "./static",
    "./templates"
  ],
  "scripts": {
    "build": "swc --delete-dir-on-start --strip-leading-paths --out-dir dist/ src --ignore '**/*.test.ts'",
    "postbuild": "pnpm run manifest:generate",
    "build:types": "pkg-utils build --emitDeclarationOnly",
    "check:types": "tsc --noEmit",
    "lint": "eslint .",
    "manifest:generate": "oclif manifest",
    "manifest:remove": "rimraf oclif.manifest.json",
    "prepack": "pnpm run manifest:generate",
    "postpack": "rimraf oclif.manifest.json",
    "publint": "publint",
    "readme": "oclif readme --tsconfig-path tsconfig.lib.json",
    "test": "vitest run",
    "posttest": "pnpm run lint",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "prewatch": "pnpm run manifest:remove",
    "watch": "swc --delete-dir-on-start --strip-leading-paths --out-dir dist/ --watch src"
  },
  "dependencies": {
    "@babel/traverse": "^7.29.0",
    "@oclif/core": "catalog:",
    "@oclif/plugin-help": "catalog:",
    "@oclif/plugin-not-found": "catalog:",
    "@rexxars/gitconfiglocal": "^3.0.1",
    "@sanity/cli-core": "workspace:*",
    "@sanity/client": "catalog:",
    "@sanity/codegen": "catalog:",
    "@sanity/descriptors": "^1.3.0",
    "@sanity/export": "^6.0.5",
    "@sanity/generate-help-url": "^4.0.0",
    "@sanity/id-utils": "^1.0.0",
    "@sanity/import": "^4.1.2",
    "@sanity/migrate": "^5.2.5",
    "@sanity/runtime-cli": "^13.4.1",
    "@sanity/schema": "catalog:",
    "@sanity/telemetry": "catalog:",
    "@sanity/template-validator": "^3.0.0",
    "@sanity/types": "catalog:",
    "@sanity/ui": "^3.1.11",
    "@vercel/frameworks": "3.8.4",
    "@vercel/fs-detectors": "5.5.2",
    "@vitejs/plugin-react": "catalog:",
    "chokidar": "^5.0.0",
    "console-table-printer": "^2.15.0",
    "date-fns": "^4.1.0",
    "debug": "catalog:",
    "dotenv": "^17.2.3",
    "eventsource": "^4.1.0",
    "execa": "catalog:",
    "form-data": "^4.0.5",
    "get-latest-version": "^6.0.1",
    "git-user-info": "^2.0.3",
    "gunzip-maybe": "^1.4.2",
    "import-meta-resolve": "catalog:",
    "install-peerdeps": "^3.0.7",
    "is-installed-globally": "^1.0.0",
    "is-tar": "^1.0.0",
    "isomorphic-dompurify": "^2.32.0",
    "json5": "^2.2.3",
    "jsonc-parser": "^3.3.1",
    "lodash-es": "^4.17.21",
    "minimist": "^1.2.8",
    "nanoid": "^5.1.5",
    "node-html-parser": "^7.0.1",
    "oneline": "^2.0.0",
    "open": "^10.1.0",
    "p-map": "^7.0.3",
    "package-directory": "^8.1.0",
    "peek-stream": "^1.1.3",
    "pluralize-esm": "^9.0.5",
    "preferred-pm": "^4.1.1",
    "pretty-ms": "^9.3.0",
    "promise-props-recursive": "^2.0.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-is": "^19.2.4",
    "read-package-up": "catalog:",
    "recast": "^0.23.11",
    "rimraf": "catalog:",
    "rxjs": "catalog:",
    "semver": "^7.7.2",
    "semver-compare": "^1.0.0",
    "smol-toml": "^1.6.0",
    "tar": "^7.5.6",
    "tar-fs": "^3.1.0",
    "tar-stream": "^3.1.7",
    "tinyglobby": "catalog:",
    "tsx": "catalog:",
    "vite": "catalog:",
    "which": "^5.0.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@eslint/compat": "catalog:",
    "@repo/package.config": "workspace:*",
    "@repo/tsconfig": "workspace:*",
    "@sanity/cli-test": "workspace:*",
    "@sanity/eslint-config-cli": "workspace:*",
    "@sanity/pkg-utils": "catalog:",
    "@swc/cli": "catalog:",
    "@swc/core": "catalog:",
    "@types/babel__traverse": "^7.28.0",
    "@types/debug": "catalog:",
    "@types/gunzip-maybe": "^1.4.3",
    "@types/lodash-es": "^4.17.12",
    "@types/minimist": "^1.2.5",
    "@types/node": "catalog:",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-is": "^19.2.0",
    "@types/semver": "^7.7.1",
    "@types/semver-compare": "^1.0.3",
    "@types/tar-fs": "^2.0.4",
    "@types/tar-stream": "^3.1.4",
    "@types/which": "^3.0.4",
    "@vitest/coverage-istanbul": "catalog:",
    "@vitest/utils": "^4.0.18",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "catalog:",
    "nock": "catalog:",
    "oclif": "^4.22.79",
    "prettier": "catalog:",
    "publint": "catalog:",
    "rimraf": "catalog:",
    "sanity": "catalog:",
    "typescript": "catalog:",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=20.19.1 <22 || >=22.12"
  },
  "publishConfig": {
    "access": "public"
  }
}
