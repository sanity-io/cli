{
  "name": "@sanity/cli",
  "version": "0.0.0",
  "private": true,
  "description": "Sanity CLI tool for managing Sanity projects and organizations",
  "keywords": [
    "sanity",
    "cms",
    "headless",
    "realtime",
    "content",
    "cli",
    "tool"
  ],
  "homepage": "https://github.com/sanity-io/cli",
  "bugs": "https://github.com/sanity-io/cli/issues",
  "repository": "sanity-io/cli",
  "license": "MIT",
  "author": "Sanity.io <hello@sanity.io>",
  "type": "module",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "sanity": "./bin/run.js"
  },
  "files": [
    "./bin",
    "./codemods",
    "./dist",
    "./oclif.config.js",
    "./oclif.manifest.json"
  ],
  "scripts": {
    "build": "swc --delete-dir-on-start --strip-leading-paths --out-dir dist/ src",
    "postbuild": "pnpm run manifest:generate",
    "build:types": "tsc --project tsconfig.lib.json",
    "check:types": "tsc --noEmit",
    "lint": "eslint .",
    "manifest:generate": "oclif manifest",
    "manifest:remove": "rimraf oclif.manifest.json",
    "prepack": "pnpm run manifest:generate",
    "postpack": "rimraf oclif.manifest.json",
    "test": "vitest run",
    "posttest": "pnpm run lint",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "version": "oclif readme && git add README.md",
    "prewatch": "pnpm run manifest:remove",
    "watch": "swc --delete-dir-on-start --strip-leading-paths --out-dir dist/ --watch src"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.8.6",
    "@oclif/core": "^4.5.3",
    "@oclif/plugin-help": "^6.2.32",
    "@oclif/plugin-not-found": "^3.2.67",
    "@sanity/cli-core": "workspace:*",
    "@sanity/client": "^7.11.2",
    "eventsource": "^4.0.0",
    "@sanity/export": "^3.45.3",
    "@sanity/generate-help-url": "^3.0.0",
    "@sanity/id-utils": "^1.0.0",
    "@sanity/import": "^4.0.0",
    "@sanity/runtime-cli": "^10.4.1",
    "@sanity/telemetry": "^0.8.1",
    "@vitejs/plugin-react": "^4.5.0",
    "boxen": "^8.0.1",
    "chalk": "^5.4.1",
    "chokidar": "^4.0.3",
    "console-table-printer": "^2.14.6",
    "date-fns": "^4.1.0",
    "debug": "^4.4.3",
    "execa": "^9.6.0",
    "form-data": "^4.0.3",
    "get-it": "^8.6.9",
    "get-latest-version": "^5.1.0",
    "glob": "^11.0.3",
    "jsdom": "^26.0.0",
    "json5": "^2.2.3",
    "lodash-es": "^4.17.21",
    "nanoid": "^5.1.5",
    "node-html-parser": "^7.0.1",
    "oneline": "^2.0.0",
    "open": "^10.1.0",
    "ora": "^8.2.0",
    "p-map": "^7.0.3",
    "pkg-dir": "^8.0.0",
    "preferred-pm": "^4.1.1",
    "pretty-ms": "^9.3.0",
    "promise-props-recursive": "^2.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "read-package-up": "^11.0.0",
    "resolve-from": "^5.0.0",
    "rxjs": "^7.8.1",
    "semver": "^7.7.2",
    "semver-compare": "^1.0.0",
    "tar-fs": "^3.1.0",
    "tsx": "^4.19.3",
    "vite": "^7.1.6",
    "which": "^5.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/compat": "catalog:",
    "@oclif/test": "^4.1.13",
    "@repo/eslint-config": "workspace:*",
    "@repo/tsconfig": "workspace:*",
    "@sanity/cli-test": "workspace:*",
    "@swc/cli": "^0.7.8",
    "@swc/core": "^1.13.2",
    "@types/debug": "^4.1.12",
    "@types/jsdom": "^21.1.7",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^20.17.23",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@types/semver": "^7.7.0",
    "@types/semver-compare": "^1.0.3",
    "@types/tar-fs": "^2.0.4",
    "@types/which": "^3.0.4",
    "@vitest/coverage-istanbul": "^3.1.3",
    "chokidar": "^4.0.3",
    "eslint": "catalog:",
    "glob": "^11.0.3",
    "nock": "^14.0.6",
    "oclif": "^4.22.18",
    "rimraf": "^6.0.1",
    "typescript": "^5.8.3",
    "vitest": "^3.1.3"
  },
  "engines": {
    "node": ">=20.19.1 <22 || >=22.12"
  }
}
