{
  "name": "@sanity/cli",
  "version": "6.0.0-alpha.5",
  "description": "Sanity CLI tool for managing Sanity projects and organizations",
  "keywords": [
    "sanity",
    "cms",
    "headless",
    "realtime",
    "content",
    "cli",
    "tool"
  ],
  "homepage": "https://github.com/sanity-io/cli",
  "bugs": "https://github.com/sanity-io/cli/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sanity-io/cli.git",
    "directory": "packages/@sanity/cli"
  },
  "license": "MIT",
  "author": "Sanity.io <hello@sanity.io>",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "sanity": "./bin/run.js"
  },
  "files": [
    "./bin",
    "./codemods",
    "./dist",
    "./oclif.config.js",
    "./oclif.manifest.json",
    "./templates"
  ],
  "scripts": {
    "build": "swc --delete-dir-on-start --strip-leading-paths --out-dir dist/ src --ignore '**/*.test.ts'",
    "postbuild": "pnpm run manifest:generate",
    "build:types": "tsc --project tsconfig.lib.json",
    "check:types": "tsc --noEmit",
    "lint": "eslint .",
    "manifest:generate": "oclif manifest",
    "manifest:remove": "rimraf oclif.manifest.json",
    "prepack": "pnpm run manifest:generate",
    "postpack": "rimraf oclif.manifest.json",
    "publint": "publint",
    "test": "vitest run",
    "posttest": "pnpm run lint",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "version": "oclif readme && git add README.md",
    "prewatch": "pnpm run manifest:remove",
    "watch": "swc --delete-dir-on-start --strip-leading-paths --out-dir dist/ --watch src"
  },
  "dependencies": {
    "@oclif/core": "catalog:",
    "@oclif/plugin-help": "catalog:",
    "@oclif/plugin-not-found": "catalog:",
    "@sanity/cli-core": "workspace:*",
    "@sanity/client": "catalog:",
    "@sanity/descriptors": "^1.3.0",
    "@sanity/export": "^6.0.2",
    "@sanity/id-utils": "^1.0.0",
    "@sanity/import": "^4.0.3",
    "@sanity/migrate": "^5.2.1",
    "@sanity/runtime-cli": "^12.4.0",
    "@sanity/schema": "catalog:",
    "@sanity/telemetry": "^0.8.1",
    "@sanity/template-validator": "^2.4.3",
    "@sanity/types": "catalog:",
    "@sanity/ui": "^3.1.11",
    "@vercel/frameworks": "3.8.4",
    "@vercel/fs-detectors": "5.5.2",
    "@vitejs/plugin-react": "catalog:",
    "boxen": "^8.0.1",
    "chokidar": "^4.0.3",
    "console-table-printer": "^2.14.6",
    "date-fns": "^4.1.0",
    "debug": "catalog:",
    "eventsource": "^4.1.0",
    "execa": "catalog:",
    "form-data": "^4.0.5",
    "get-it": "^8.7.0",
    "get-latest-version": "^5.1.0",
    "get-tsconfig": "catalog:",
    "gunzip-maybe": "^1.4.2",
    "is-tar": "^1.0.0",
    "isomorphic-dompurify": "^2.32.0",
    "json5": "^2.2.3",
    "lodash-es": "^4.17.21",
    "nanoid": "^5.1.5",
    "node-html-parser": "^7.0.1",
    "oneline": "^2.0.0",
    "open": "^10.1.0",
    "p-map": "^7.0.3",
    "package-directory": "^8.1.0",
    "peek-stream": "^1.1.3",
    "preferred-pm": "^4.1.1",
    "pretty-ms": "^9.3.0",
    "promise-props-recursive": "^2.0.2",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-is": "^19.2.1",
    "read-package-up": "^11.0.0",
    "resolve-from": "^5.0.0",
    "rxjs": "^7.8.1",
    "sanity": "catalog:",
    "semver": "^7.7.2",
    "semver-compare": "^1.0.0",
    "styled-components": "^6.1.19",
    "tar": "^7.4.3",
    "tar-fs": "^3.1.0",
    "tar-stream": "^3.1.7",
    "tinyglobby": "^0.2.15",
    "tsx": "catalog:",
    "vite": "catalog:",
    "which": "^5.0.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@eslint/compat": "catalog:",
    "@oclif/test": "catalog:",
    "@repo/tsconfig": "workspace:*",
    "@sanity/cli-test": "workspace:*",
    "@sanity/eslint-config-cli": "workspace:*",
    "@swc/cli": "catalog:",
    "@swc/core": "catalog:",
    "@types/debug": "catalog:",
    "@types/gunzip-maybe": "^1.4.3",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "catalog:",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/react-is": "^19.2.0",
    "@types/semver": "^7.7.1",
    "@types/semver-compare": "^1.0.3",
    "@types/tar-fs": "^2.0.4",
    "@types/tar-stream": "^3.1.4",
    "@types/which": "^3.0.4",
    "@vitest/coverage-istanbul": "catalog:",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "catalog:",
    "nock": "catalog:",
    "oclif": "^4.22.57",
    "publint": "catalog:",
    "rimraf": "catalog:",
    "typescript": "catalog:",
    "vite-tsconfig-paths": "^6.0.3",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=20.19.1 <22 || >=22.12"
  },
  "publishConfig": {
    "access": "public"
  }
}
