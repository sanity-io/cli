{
  "name": "@sanity/cli",
  "version": "0.0.0",
  "private": true,
  "description": "Sanity CLI tool for managing Sanity projects and organizations",
  "keywords": [
    "sanity",
    "cms",
    "headless",
    "realtime",
    "content",
    "cli",
    "tool"
  ],
  "homepage": "https://github.com/sanity-io/cli",
  "bugs": "https://github.com/sanity-io/cli/issues",
  "repository": "sanity-io/cli",
  "license": "MIT",
  "author": "Sanity.io <hello@sanity.io>",
  "type": "module",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.js"
    }
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "sanity": "./bin/run.js"
  },
  "files": [
    "./bin",
    "./dist",
    "./oclif.config.js",
    "./oclif.manifest.json"
  ],
  "scripts": {
    "build": "swc --delete-dir-on-start --strip-leading-paths --out-dir dist/ src",
    "lint": "eslint .",
    "prepack": "oclif manifest && oclif readme",
    "postpack": "rimraf oclif.manifest.json",
    "test": "vitest run",
    "posttest": "pnpm run lint",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "version": "oclif readme && git add README.md",
    "watch": "swc --delete-dir-on-start --strip-leading-paths --out-dir dist/ --watch src"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.3.2",
    "@oclif/core": "^4.3.0",
    "@oclif/plugin-help": "^6.2.28",
    "@oclif/plugin-not-found": "^3.2.51",
    "@sanity/client": "^7.0.0",
    "debug": "^4.4.0",
    "get-tsconfig": "^4.10.0",
    "import-meta-resolve": "^4.1.0",
    "jsdom": "^26.0.0",
    "open": "^10.1.0",
    "ora": "^8.2.0",
    "ts-blank-space": "^0.6.1",
    "tsx": "^4.19.3",
    "vite": "^6.3.5",
    "vite-node": "^3.0.8",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/compat": "^1.2.9",
    "@oclif/test": "^4.1.12",
    "@repo/eslint-config": "workspace:*",
    "@swc/cli": "^0.6.0",
    "@swc/core": "^1.11.8",
    "@types/debug": "^4.1.12",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^20.17.23",
    "@vitest/coverage-v8": "^3.1.2",
    "ansis": "^3.17.0",
    "eslint": "^9.26.0",
    "oclif": "^4.17.34",
    "rimraf": "^6.0.1",
    "typescript": "^5.8.2",
    "vitest": "^3.1.2"
  },
  "engines": {
    "node": ">=20.19.1"
  }
}
