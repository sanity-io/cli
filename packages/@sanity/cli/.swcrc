{
  "$schema": "https://swc.rs/schema.json",
  "jsc": {
    "parser": {
      "syntax": "typescript",
      "tsx": true,
      "jsx": true
    },
    "transform": {
      "react": {
        "runtime": "automatic"
      }
    },
    "target": "es2023"
  },
  "module": {
    "type": "nodenext"
  },
  "isModule": true,
  "sourceMaps": true
}
