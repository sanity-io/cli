{
  "name": "@sanity/cli-test",
  "version": "6.0.0",
  "description": "Sanity CLI test helpers and utilities",
  "keywords": [
    "cli",
    "cms",
    "content",
    "headless",
    "realtime",
    "sanity",
    "tool"
  ],
  "homepage": "https://github.com/sanity-io/cli",
  "bugs": "https://github.com/sanity-io/cli/issues",
  "license": "MIT",
  "author": "Sanity.io <hello@sanity.io>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sanity-io/cli.git",
    "directory": "packages/@sanity/cli-test"
  },
  "files": [
    "./dist",
    "./fixtures"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./mocks/cli-core/apiClient": {
      "source": "./src/mocks/cli-core/apiClient.ts",
      "default": "./dist/mocks/cli-core/apiClient.js"
    },
    "./mocks/cli-core/browser": {
      "source": "./src/mocks/cli-core/browser.ts",
      "default": "./dist/mocks/cli-core/browser.js"
    },
    "./mocks/cli-core/config": {
      "source": "./src/mocks/cli-core/config.ts",
      "default": "./dist/mocks/cli-core/config.js"
    },
    "./mocks/cli-core/package-manager": {
      "source": "./src/mocks/cli-core/package-manager.ts",
      "default": "./dist/mocks/cli-core/package-manager.js"
    },
    "./mocks/cli-core/request": {
      "source": "./src/mocks/cli-core/request.ts",
      "default": "./dist/mocks/cli-core/request.js"
    },
    "./mocks/cli-core/tasks": {
      "source": "./src/mocks/cli-core/tasks.ts",
      "default": "./dist/mocks/cli-core/tasks.js"
    },
    "./mocks/cli-core/telemetry": {
      "source": "./src/mocks/cli-core/telemetry.ts",
      "default": "./dist/mocks/cli-core/telemetry.js"
    },
    "./mocks/cli-core/ux": {
      "source": "./src/mocks/cli-core/ux.ts",
      "default": "./dist/mocks/cli-core/ux.js"
    },
    "./mocks/cli-core/SanityCommand": {
      "source": "./src/mocks/cli-core/SanityCommand.ts",
      "default": "./dist/mocks/cli-core/SanityCommand.js"
    },
    "./paths": {
      "source": "./src/utils/paths.ts",
      "default": "./dist/utils/paths.js"
    },
    "./test/createTestClient": {
      "source": "./src/test/createTestClient.ts",
      "default": "./dist/test/createTestClient.js"
    },
    "./test/mockApi": {
      "source": "./src/test/mockApi.ts",
      "default": "./dist/test/mockApi.js"
    },
    "./test/oclif": {
      "source": "./src/test/oclif.ts",
      "default": "./dist/test/oclif.js"
    },
    "./test/setupFixtures": {
      "source": "./src/test/setupFixtures.ts",
      "default": "./dist/test/setupFixtures.js"
    },
    "./test/util": {
      "source": "./src/test/util.ts",
      "default": "./dist/test/util.js"
    },
    "./vitest": {
      "source": "./src/vitest.ts",
      "default": "./dist/vitest.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prebuild": "pnpm run clean",
    "build": "pnpm run build:js && pnpm run copy:fixtures",
    "build:js": "swc --delete-dir-on-start --strip-leading-paths --out-dir dist/ src",
    "build:types": "pkg-utils build --emitDeclarationOnly",
    "check:types": "tsc --noEmit",
    "clean": "rimraf dist fixtures",
    "copy:fixtures": "tsx scripts/copy-fixtures.ts",
    "lint": "eslint .",
    "publint": "publint",
    "test": "vitest run",
    "posttest": "pnpm run lint",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "watch": "swc --delete-dir-on-start --strip-leading-paths --out-dir dist/ --watch src"
  },
  "dependencies": {
    "@sanity/cli-core": "workspace:*",
    "@swc/core": "catalog:",
    "ansis": "^4.2.0",
    "esbuild": "^0.28.1",
    "get-it": "^9.1.0",
    "nock": "catalog:",
    "tinyglobby": "catalog:"
  },
  "devDependencies": {
    "@eslint/compat": "catalog:",
    "@oclif/core": "catalog:",
    "@repo/package.config": "workspace:*",
    "@repo/tsconfig": "workspace:*",
    "@sanity/client": "^7.23.2",
    "@sanity/eslint-config-cli": "workspace:*",
    "@sanity/pkg-utils": "catalog:",
    "@swc/cli": "catalog:",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "publint": "catalog:",
    "rimraf": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "yaml": "catalog:"
  },
  "peerDependencies": {
    "@oclif/core": "^4.0.0",
    "@sanity/cli-core": "workspace:*",
    "@sanity/client": "^7.0.0",
    "vitest": ">=3.0.0 <5.0.0"
  },
  "engines": {
    "node": ">=22.12"
  }
}
